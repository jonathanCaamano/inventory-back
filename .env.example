# Server
PORT=8080
ENV=development
MAX_REQUEST_SIZE_MB=10

# CORS — comma-separated allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=inventory
DB_PASSWORD=inventory_password
DB_NAME=inventory
DB_SSL_MODE=disable

# JWT — REQUIRED, must be >= 32 chars (generate: openssl rand -hex 32)
JWT_SECRET=replace_with_at_least_32_character_secret_key_here
JWT_ACCESS_TTL_HOURS=24

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=inventory
MINIO_USE_SSL=false
MINIO_MAX_UPLOAD_MB=5
